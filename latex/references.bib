@article{GorgensMomentRestrictionsIdentification2019,
  title = {Moment {{Restrictions}} and {{Identification}} in {{Linear Dynamic Panel Data Models}}},
  author = {{G{\o}rgens} and {Han} and {Xue}},
  year = {2019},
  journal = {Annals of Economics and Statistics},
  number = {134},
  eprint = {10.15609/annaeconstat2009.134.0149},
  eprinttype = {jstor},
  pages = {149},
  issn = {21154430},
  doi = {10.15609/annaeconstat2009.134.0149},
  url = {https://www.jstor.org/stable/10.15609/annaeconstat2009.134.0149},
  urldate = {2025-08-12},
  abstract = {This paper investigates the relationship between moment restrictions and identification in simple linear AR(1) dynamic panel data models with fixed effects under standard minimal assumptions. The number of time periods is assumed to be small. The assumptions imply linear and quadratic moment restrictions which can be used for GMM estimation. The paper makes three points. First, contrary to common belief, the linear moment restrictions may fail to identify the autoregressive parameter even when it is known to be less than 1. Second, the quadratic moment restrictions provide full or partial identification in many of the cases where the linear moment restrictions do not. Third, the first moment restrictions can also be important for identification. Practical implications of the findings are illustrated using Monte Carlo simulations. JEL Codes: C230.},
  langid = {english},
  keywords = {/unread}
}

