@article{CarneiroANALISEDOSDETERMINANTES,
  title = {{AN{\'A}LISE DOS DETERMINANTES DA EFICI{\^E}NCA DA APLICA{\c C}{\~A}O DOS RECURSOS DO FNE PELOS MUNIC{\'I}PIOS BENEFICIADOS}},
  author = {Carneiro, Diego and Shirasu, Mait{\^e}},
  abstract = {This article aims to evaluate the efficiency of Northeastern municipalities in transforming the resources taken from the FNE in economic growth. In order to do so, the Stochastic Border Approach and Data Envelopment Analysis were used in conjunction with a two-stage estimation to explain the determinants of this efficiency. The combination of the methods of the most robustness to the result by allowing a greater flexibility in the assumed hypotheses. Estimates have shown that there is a concentration of highly efficient municipalities in the region known as MATOPIBA, and this seems to be linked to the adoption of extensive, exportoriented agriculture. There was also a positive effect regarding the proportion of workers with higher level over technical efficiency. Thus, it is believed that the creation of products that facilitate the international insertion of producers as well as the accumulation of human capital would tend to increase the impact of the policy.},
  langid = {portuguese},
  keywords = {No DOI found}
}

@article{CarneiroAVALIACAOEFICIENCIAEMPRESAS,
  title = {{AVALIA{\c C}{\~A}O DE EFICI{\^E}NCIA DAS EMPRESAS BENEFICIADAS PELA POL{\'I}TICA DE INCENTIVOS FISCAIS CONDUZIDA PELA SUDENE}},
  author = {Carneiro, Diego and Costa, Edward and Irffi, Guilherme and Braz, Marleton and Dias, Thyena and Andrade, Vanessa},
  abstract = {Brazil is characterized by profound regional inequalities, with the Northeast of the country being one of the regions that accentuates these disparities the most. In order to mitigate this issue, the Brazilian government has been granting incentives and tax benefits to enterprises that establish themselves in the region. The scarce literature on this topic is controversial regarding the effects of this policy on the level of economic efficiency. In this context, this study aims to estimate the technical efficiency of firms that benefited from the 75\% reduction in Corporate Income Tax (IRPJ) incentive, managed by SUDENE. To do so, the DEA and Stochastic Frontier methods were employed, using the number of employees and projected investment as inputs, while the variation in payroll two years after receiving the benefit was used as the output. The results suggest that although there is a certain degree of inefficiency among the benefited companies, it is more related to the type of incentivized sector rather than the companies within it. Efficient companies were also observed in the semiarid region, indicating that the policy is achieving its objectives in this priority zone. As for the results of the stochastic frontier, it was found that the incentivized companies, on average, are more labor-intensive, refuting the criticism that fiscal incentives stimulate capital-prevalent enterprises.},
  langid = {portuguese},
  keywords = {No DOI found}
}

