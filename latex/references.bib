@article{Oliveira2016,
  title = {Fundo {{Constitucional de Financiamento do Centro-Oeste}} ({{FCO}}) em {{Goi{\'a}s}}: uma Aplica{\c c}{\~a}o Econom{\'e}trica-Espacial},
  author = {Oliveira, Guilherme Resende and Lima, Alex Felipe Rodrigues and Arriel, Marcos Fernando},
  year = {2016},
  journal = {Revista Brasileira de Economia de Empresas},
  volume = {16},
  number = {1},
  abstract = {Este estudo examina a influência do espaço na distribuição de recursos do Fundo Constitucional de Financiamento do Centro-Oeste (FCO) entre 2004 e 2011 nos municípios goianos. As correlações espaciais foram verificadas por meio do Índice de Moran global, que mostrou que a distribuição do FCO não depende somente das atividades econômicas do município, mas também é fortemente influenciada, de maneira positiva, pelo nível de recursos que circula na vizinhança. O modelo autoregressivo espacial com efeitos fixos mostrou que o FCO afeta positivamente as atividades econômicas e a geração de empregos nos municípios. Esse resultado havia sido encontrado pela literatura, entretanto os coeficientes eram superestimados por não levar em conta a questão espacial, que aumenta significativamente o poder de explicação.},
  url = {https://portalrevistas.ucb.br/index.php/rbee/article/view/6832}}

