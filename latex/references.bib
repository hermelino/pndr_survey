@article{MarinEconomiaPoliticaIsencoes,
  title = {{A Economia Pol{\'i}tica das Isen{\c c}{\~o}es Fiscais: Teoria e Evid{\^e}ncia.}},
  author = {Marin, Gabriel F},
  abstract = {Tax exemptions are widely used by politicians in the conduct of their mandates. In particular, in Brazil, this relationship became evident after the granting of the Federal Constitution in 1988, which granted greater fiscal autonomy to states and municipalities. We built a competence signaling model, where only the competent politician has information about the magnitude of social benefits arising from tax exemptions. Our model provides a theoretical basis for some recent discoveries in the empirical literature, such as the increase in tax exemptions in election years. In particular, we find that under certain conditions, a competent politician has incentives to grant tax exemptions, even in the possession of information that these are socially bad. We demonstrate for the Brazilian political scene -- more specifically for the State of Rio Grande do Sul -- that the main hypothesis of our model, that voters punish politicians who do not provide exemptions, is supported by data.},
  langid = {portuguese},
  keywords = {No DOI found}
}

@article{MatosPapelDosGastos2024,
  title = {O Papel Dos Gastos Correntes e de Capital Dos Governos Estaduais e Municipais No Crescimento Cross-State No {{Brasil}} Entre 2003 e 2019},
  author = {Matos, Paulo Rog{\'e}rio Faustino and Costa, Lorena and Simonassi, Andrei},
  year = {2024},
  month = nov,
  journal = {Revista Brasileira de Economia},
  volume = {78},
  number = {3},
  issn = {1806-9134},
  url = {https://periodicos.fgv.br/rbe/article/view/89623},
  urldate = {2025-08-15},
  abstract = {We address the role played by local government spending in cross-state growth, over the widest available period from the adoption of the Fiscal Responsibility Law (FRL). We estimate an extended version of Barro-style growth panel regression in difference, controlling for exports, imports, years of schooling, enterprise and household credit. We find that the parameters associated with capital expenditures for state and municipal governments are respectively 1.23 and 5.35, while the parameters of current expenditures for state and municipal governments are -1.28 and -2.61. We do not find a significant role of municipal and state government credit.},
  copyright = {Copyright (c) 2024 Revista Brasileira de Economia},
  langid = {english},
  keywords = {growth,No DOI found,Portugues (Brasil)}
}

@article{MauesfilhoAVALIACAOFUNDOCONSTITUCIONAL2024,
  title = {{AVALIA{\c C}{\~A}O DO FUNDO CONSTITUCIONAL DO NORTE (FNO) NO FOMENTO DE INDICADORES SOCIOECON{\^O}MICOS: UM ESTUDO NO ESTADO DO PAR{\'A} NO PER{\'I}ODO ENTRE 2010 E 2019}},
  shorttitle = {{AVALIA{\c C}{\~A}O DO FUNDO CONSTITUCIONAL DO NORTE (FNO) NO FOMENTO DE INDICADORES SOCIOECON{\^O}MICOS}},
  author = {Mau{\'e}s Filho, Carlos Benassuly and Moreira, Marcia Athayde and Da Silva, Evaldo Jos{\'e} and Martins, Cyntia Meireles},
  year = {2024},
  month = feb,
  journal = {Revista Brasileira de Gest{\~a}o e Desenvolvimento Regional},
  volume = {20},
  number = {1},
  issn = {1809-239X},
  doi = {10.54399/rbgdr.v20i1.6406},
  url = {https://www.rbgdr.net/revista/index.php/rbgdr/article/view/6406},
  urldate = {2025-08-12},
  abstract = {The objective of the research was to evaluate whether, and to what extent, the amounts released from the Northern Constitutional Financing Fund (FNO) influenced, in the period analyzed, the generation of direct revenue by municipalities and municipal development indices in state of Par{\'a}. To carry out the research, the values released by the FNO, the direct revenues of Par{\'a} municipalities and the FIRJAN Municipal Development indices were collected, relating to the 144 municipalities in state of Par{\'a}, in a time frame from 2010 to 2016 for FIRJAN and, from 2010 to 2019 for FNO and municipal revenues, with data processing using panel regressions. In the analysis of values released by FNO, no influence was found on Municipal Direct Revenues, but an influence was found on IFDM General, IFDM Education and IFDM Health, which suggests a greater impact of credit on the social variable. It is concluded that the data obtained in the research were sufficient, only partially, to prove the contribution of the FNO in obtaining, maintaining and growing, in a linear manner, the collection of direct municipal revenues and in the generation of employment and income. The results can be used to improve the allocation of credit resources in Par{\'a} state, contributing to better decision-making by public and private actors as well as the efficiency of credit aimed at regional development.},
  copyright = {https://creativecommons.org/licenses/by-nc/4.0},
  langid = {portuguese}
}

@article{MauesfilhoEfeitosFNONo2023,
  title = {{Efeitos do FNO no desenvolvimento da mesorregi{\~a}o do Maraj{\'o} no estado do Par{\'a}}},
  author = {Mau{\'e}s Filho, Carlos Benassuly and Moreira, M{\'a}rcia Athayde and Martins, Cyntia Meireles and Oliveira, Ronny Luis Sousa},
  year = {2023},
  month = dec,
  journal = {DRd - Desenvolvimento Regional em debate},
  volume = {13},
  pages = {510--530},
  issn = {2237-9029},
  doi = {10.24302/drd.v13.4279},
  url = {https://www.periodicos.unc.br/index.php/drd/article/view/4279},
  urldate = {2025-08-12},
  abstract = {O objetivo geral desta pesquisa foi avaliar se, e em que medida, os valores liberados do Fundo Constitucional de Financiamento do Norte (FNO) influenciaram, no per{\'i}odo analisado, as receitas diretas e os {\'i}ndices de desenvolvimento da Regi{\~a}o de Integra{\c c}{\~a}o do Maraj{\'o} no Estado do Par{\'a}. Para a realiza{\c c}{\~a}o da pesquisa, foram coletados os valores liberados pelo FNO, as receitas diretas e os {\'i}ndices FIRJAN de Desenvolvimento, relativos aos 16 munic{\'i}pios que integram esta regi{\~a}o; em corte temporal de 2010 a 2016 para os {\'i}ndices FIRJAN e, de 2010 a 2019, para o FNO e as receitas municipais, com tratamento dos dados por regress{\~o}es em painel. Conclui-se que esta an{\'a}lise trouxe uma complexidade de resultados que antes n{\~a}o foram expostos e que levam a uma necessidade de aprofundamento de estudos para futuras discuss{\~o}es, na busca de solu{\c c}{\~o}es para a efici{\^e}ncia das pol{\'i}ticas destinadas ao desenvolvimento social do estado do Par{\'a}. Palavras-Chave: Fundo Constitucional do Norte. Desenvolvimento Regional. Indicadores Socioecon{\^o}micos. Regi{\~a}o de Integra{\c c}{\~a}o do Maraj{\'o}.},
  copyright = {https://creativecommons.org/licenses/by-nd/4.0},
  langid = {portuguese}
}

@article{MendezRegionalUnemploymentDynamics2023,
  title = {Regional Unemployment Dynamics in {{Indonesia}}: Serial Persistence, Spatial Dependence, and Common Factors},
  shorttitle = {Regional Unemployment Dynamics in {{Indonesia}}},
  author = {Mendez, Carlos and Siregar, Tifani Husna},
  year = {2023},
  month = dec,
  journal = {Letters in Spatial and Resource Sciences},
  volume = {16},
  number = {1},
  pages = {40},
  issn = {1864-4031, 1864-404X},
  doi = {10.1007/s12076-023-00364-6},
  url = {https://link.springer.com/10.1007/s12076-023-00364-6},
  urldate = {2025-08-12},
  abstract = {We analyze the space-time dynamics of Indonesia's provincial unemployment by simultaneously accounting for their serial persistence, spatial dependence, and common factors. The results show that unemployment rates vary widely across provinces, but have similar patterns over time, indicating the presence of common latent factors. Using the average national unemployment rate as a proxy for common factors, the results indicate that the space-time dynamics of provincial unemployment are characterized by both significant serial persistence and spatial dependence. The results also quantify which regions are most sensitive to national unemployment shocks, providing a deeper understanding of regional unemployment heterogeneity.},
  langid = {english},
  keywords = {/unread}
}

