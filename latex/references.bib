@article{HansenInferenceIteratedGMM2021,
  title = {Inference for {{Iterated GMM Under Misspecification}}},
  author = {Hansen, Bruce E. and Lee, Seojeong},
  year = {2021},
  journal = {Econometrica},
  volume = {89},
  number = {3},
  pages = {1419--1447},
  issn = {0012-9682},
  doi = {10.3982/ECTA16274},
  url = {https://www.econometricsociety.org/doi/10.3982/ECTA16274},
  urldate = {2025-08-12},
  abstract = {This paper develops inference methods for the iterated overidentified Generalized Method of Moments (GMM) estimator. We provide conditions for the existence of the iterated estimator and an asymptotic distribution theory, which allows for mild misspecification. Moment misspecification causes bias in conventional GMM variance estimators, which can lead to severely oversized hypothesis tests. We show how to consistently estimate the correct asymptotic variance matrix. Our simulation results show that our methods are properly sized under both correct specification and mild to moderate misspecification. We illustrate the method with an application to the model of Acemoglu, Johnson, Robinson, and Yared (2008).},
  langid = {english},
  keywords = {/unread}
}

@article{HarrisSearch2011,
  title = {In {{Search}} of ` {{{\emph{W}}}} '},
  author = {Harris, Richard and Moffat, John and Kravtsova, Victoria},
  year = {2011},
  month = sep,
  journal = {Spatial Economic Analysis},
  volume = {6},
  number = {3},
  pages = {249--270},
