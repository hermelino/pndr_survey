@article{EhrlMinimumComparableAreas2017,
  title = {Minimum Comparable Areas for the Period 1872-2010: An Aggregation of {{Brazilian}} Municipalities},
  shorttitle = {Minimum Comparable Areas for the Period 1872-2010},
  author = {Ehrl, Philipp},
  year = {2017},
  month = mar,
  journal = {Estudos Econ{\^o}micos (S{\~a}o Paulo)},
  volume = {47},
  number = {1},
  pages = {215--229},
  issn = {0101-4161},
  doi = {10.1590/0101-416147182phe},
  url = {http://www.scielo.br/scielo.php?script=sci_arttext&pid=S0101-41612017000100215&lng=en&tlng=en},
  urldate = {2025-08-12},
  abstract = {Since the imperial era, the number of municipalities in Brazil has risen continually and substantially. These changes in the delineation of spatial units pose a difficulty for any research that intends to use regional data from different years. The present paper develops a routine for the generation of time-consistent `Minimum Comparable Areas' (AMC) for any arbitrary sub-period between two census years in the range between the first and last demographic census 1872--2010. It relies on recently compiled material by the Brazilian Institute for Geography and Statistics (IBGE). The corresponding Stata code is provided in the Appendix of the paper. Thus, the developed AMCs are immediately accessible and enable long-term panel studies with regional data.},
  langid = {english},
  keywords = {/unread}
}

@article{Elhorst2010,
  title = {Growth and {{Convergence}} in a {{Multiregional Model}} with {{Space}}--{{Time Dynamics}}. 多区域时空动态模型的增长与收敛},
  author = {Elhorst, Paul and Piras, Gianfranco and Arbia, Giuseppe},
  year = {2010},
  month = jul,
  journal = {Geographical Analysis},
  volume = {42},
  number = {3},
  pages = {338--355},
  issn = {0016-7363, 1538-4632},
  doi = {10.1111/j.1538-4632.2010.00796.x},
  url = {https://onlinelibrary.wiley.com/doi/10.1111/j.1538-4632.2010.00796.x},
  urldate = {2025-08-12},
  abstract = {The goal of this article is to test four distinct hypotheses about whether the relative location of an economy affects economic growth and economic well-being using an extended Solow--Swan neoclassical growth model that incorporates both space and time dynamics. We show that the econometric specification takes the form of an unconstrained spatial Durbin model, and we investigate whether the results depend on some methodological issues, such as the choice of the time span and the inclusion of fixed effects. To estimate the fixed effects spatial Solow--Swan model, we adjust the               Arrelano and Bond (1991)               generalized method-of-moments (GMM) estimator to deal with endogeneity not only arising from the initial income level, as in the basic model, but also from the initial income levels and economic growth rates observed in neighboring economies.                        ,              El objetivo de este art{\'i}culo es poner a prueba cuatro hip{\'o}tesis particulares que abordan la cuesti{\'o}n de la importancia de la ubicaci{\'o}n relativa de una econom{\'i}a y su efecto en el crecimiento y bienestar econ{\'o}mico mediante el uso de una ampliaci{\'o}n del modelo neocl{\'a}sico de crecimiento de Solow-Swan que incorpora din{\'a}micas espacio-temporales. El art{\'i}culo muestra que la especificaci{\'o}n econom{\'e}trica toma la forma de un modelo Durbin espacial sin restricciones. Asimismo, los autores eval{\'u}an los resultados en t{\'e}rminos del impacto de algunas cuestiones metodol{\'o}gicas, tales como la elecci{\'o}n del lapso de tiempo y la inclusi{\'o}n de efectos fijos. Para estimar el modelo de efectos fijos espaciales Solow-Swan, el m{\'e}todo propuesto aqu{\'i} ajusta el estimador de Arellano y Bond (1991) basado el m{\'e}todo generalizado de momentos-(GMM) para hacer frente a la endogeneidad provocada por el nivel de ingresos inicial (como lo hace modelo est{\'a}ndar), pero adem{\'a}s para encarar la endogeneidad de los niveles iniciales de ingreso y tasas de crecimiento econ{\'o}mico observados en las econom{\'i}as vecinas.           ,              本文目标是采用扩展的整合时空动力学的索罗---斯旺（Solow--Swan）新古典经济增长模型，以检验关于经济体的相对区位是否影响经济增长或经济福利的四个不同假设。计量经济学论证采用无约束的空间德宾（Durbin）模型，以研究经济时空动态增长模型的结果是否依赖于方法学的某些处理技巧，诸如时间跨度的选取和空间尺度固定效应的考虑。为了估计空间索罗---斯旺模型的固定效应，我们修正了Arrelano 和 Bond的广义矩量方法（GMM）估计量，以处理经济模型的动态增长的内生性，这种内生增长不仅源自基本模型中的初始收入水平，而且源自近邻经济体的初始收入水平与经济增长率。},
  langid = {english},
  keywords = {/unread}
}

@article{Elhorst2012,
  title = {{Dynamic Spatial Panels: Models, Methods, and Inferences}},
  shorttitle = {Dynamic Spatial Panels},
  author = {Elhorst, J. Paul},
  year = {2012},
  month = jan,
  journal = {Journal of Geographical Systems},
  volume = {14},
