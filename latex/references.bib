@article{TanParameterizingSpatialWeight2025,
  title = {Parameterizing {{Spatial Weight Matrices}} in {{Spatial Econometric Models}}},
  author = {Tan, Chang and Kesina, Michaela and Elhorst, J. Paul},
  year = {2025},
  month = jan,
  journal = {Political Analysis},
  volume = {33},
  number = {1},
  pages = {49--63},
  issn = {1047-1987, 1476-4989},
  doi = {10.1017/pan.2024.16},
  url = {https://www.cambridge.org/core/product/identifier/S1047198724000160/type/journal_article},
  urldate = {2025-08-12},
  abstract = {Spatial econometric models allow for interactions among cross-sectional units through spatial weight matrices. This paper parameterizes each spatial weight matrix in the widely used spatial Durbin model with a different instead of one common distance decay parameter, using negative exponential and inverse distance matrices. We propose a joint estimation approach of the decay and response parameters, and we investigate its performance in a Monte Carlo simulation experiment. We also present the results of an empirical application on military expenditures. Indirect effects in particular appear to be sensitive to different parameterizations.},
  copyright = {https://creativecommons.org/licenses/by/4.0},
  langid = {english},
  keywords = {/unread}
}

@article{TD2580Estoque2020,
  title = {{TD 2580 - Estoque de capital fixo no Brasil: s{\'e}ries desagregadas anuais, trimestrais e mensais}},
  shorttitle = {{TD 2580 - Estoque de capital fixo no Brasil}},
  year = {2020},
  month = sep,
  journal = {Texto para Discuss{\~a}o},
  doi = {10.38116/td2580},
  url = {https://www.ipea.gov.br/portal/images/stories/PDFs/TDs/200908_td_2580.pdf},
  urldate = {2025-08-12},
  abstract = {A s{\'e}rie hist{\'o}rica de estoque de capital {\'e} fundamental para estudos de crescimento econ{\^o}mico e para estima{\c c}{\~a}o do produto potencial -- vari{\'a}vel muito utilizada em an{\'a}lises de pol{\'i}tica macroecon{\^o}mica --, por meio da fun{\c c}{\~a}o de produ{\c c}{\~a}o. Uma das principais contribui{\c c}{\~o}es deste trabalho em rela{\c c}{\~a}o aos j{\'a} existentes {\'e} estimar o estoque de capital a partir de dados da Forma{\c c}{\~a}o Bruta de Capital Fixo (FBCF) desagregados por produto utilizando um detalhado levantamento e tratamento de dados hist{\'o}ricos. Isso faz com que poss{\'i}veis distor{\c c}{\~o}es decorrentes de mudan{\c c}a nos pre{\c c}os relativos e de mudan{\c c}as na composi{\c c}{\~a}o do investimento sejam capturadas com maior precis{\~a}o, e as estimativas da deprecia{\c c}{\~a}o e do investimento l{\'i}quido fiquem mais acuradas. Para se obter dados desagregados dessa forma, foi necess{\'a}rio adequar informa{\c c}{\~o}es de diferentes metodologias obtidas nas tabelas de recursos e usos (TRUs) e nas matrizes de insumo-produto (MIPs), bem como utilizar taxas de deprecia{\c c}{\~a}o e tempo de vida {\'u}til em n{\'i}vel de produtos. Ao t{\'e}rmino, foram obtidas estimativas anuais das seguintes vari{\'a}veis para o per{\'i}odo de 1947 a 2017: estoque l{\'i}quido de capital fixo; investimento l{\'i}quido; taxa de investimento; taxa de deprecia{\c c}{\~a}o; e rela{\c c}{\~a}o capital/produto. Outra contribui{\c c}{\~a}o deste texto {\'e} a estima{\c c}{\~a}o de s{\'e}ries com frequ{\^e}ncias mais altas (trimestral e mensal), com dados atualizados at{\'e} 2019 e compat{\'i}veis com o Sistema de Contas Nacionais (SCN) refer{\^e}ncia 2010, ampliando o escopo de aplica{\c c}{\~a}o das s{\'e}ries estimadas para an{\'a}lises de curto prazo da economia brasileira.},
  langid = {portuguese},
  keywords = {/unread}
}

