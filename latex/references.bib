@article{DebarsyInterpretingDynamicSpace2012,
  title = {{Interpreting Dynamic Space--Time Panel Data Models}},
  author = {Debarsy, Nicolas and Ertur, Cem and LeSage, James P.},
  year = {2012},
  month = jan,
  journal = {Statistical Methodology},
  volume = {9},
  number = {1-2},
  pages = {158--171},
  issn = {15723127},
  doi = {10.1016/j.stamet.2011.02.002},
  url = {https://linkinghub.elsevier.com/retrieve/pii/S1572312711000165},
  urldate = {2025-08-12},
  abstract = {There is a vast amount of literature regarding the asymptotic properties of various approaches to estimating simultaneous space--time panel models, but little attention has been paid to how the model estimates should be interpreted. The motivation for the use of space--time panel models is that they can provide us with information not available from cross-sectional spatial regressions. LeSage and Pace (2009) [7] showed that cross-sectional simultaneous spatial autoregressive models can be viewed as a limiting outcome of a dynamic space--time autoregressive process. A valuable aspect of dynamic space--time panel data models is that the ownand cross-partial derivatives that relate changes in the explanatory variables to those that arise in the dependent variables are explicit. This allows us to employ parameter estimates from these models to quantify dynamic responses over time and space as well as space--time diffusion impacts. We illustrate our approach using the demand for cigarettes over a 30 year period from 1963--1992, where the motivation for spatial dependence is a bootlegging effect where buyers of cigarettes near state borders purchase in neighboring states if there is a price advantage to doing so.},
  copyright = {https://www.elsevier.com/tdm/userlicense/1.0/},
  langid = {english},
  keywords = {/unread}
}

@article{DecamposSpatialLocationAgglomeration2023,
  title = {Spatial Location and Agglomeration Economies in Exports: Empirical Evidence by Technological Intensities in {{Brazil}}},
  shorttitle = {Spatial Location and Agglomeration Economies in Exports},
  author = {De Campos, Antonio Carlos and Lopes, Lu{\'i}s and Carreira, Carlos},
  year = {2023},
  month = dec,
  journal = {Journal of Applied Economics},
  volume = {26},
  number = {1},
  pages = {2272112},
  issn = {1514-0326, 1667-6726},
  doi = {10.1080/15140326.2023.2272112},
  url = {https://www.tandfonline.com/doi/full/10.1080/15140326.2023.2272112},
  urldate = {2025-08-12},
  abstract = {This study investigates spatial autocorrelation and the formation of spatial export clusters of Brazilian mesoregions based on technological intensity. It also analyzes how regional knowledge and agglomeration economies explain regional exports, using spatial econometric techniques. Brazilian exports exhibit a stronger spatial autocorrelation. Non-manufacturing sectors, which are less technology-intensive, exhibit lower spatial dependence than manufacturing sectors. The results also show an autocorrelation between exports and R\&D expenditure, identifying the formation of clusters in the southeastern and southern regions. R\&D expenditure fosters the growth of regional exports and the spatial lag effects of exports and R\&D expenditure are significant in the high technology-intensive manufacturing sector.},
  langid = {english},
  keywords = {/unread}
}

@article{DefreitasEfeitoFundoConstitucional2016,
  title = {{Efeito do Fundo Constitucional do Centro-Oeste na Gera{\c c}{\~a}o de Empregos}},
  author = {De Freitas, Carlos Eduardo and Arbu{\'e}s Carneiro J{\'u}nior, Jo{\~a}o Bosco and Justino, Amauri Do Prado},
  year = {2016},
  month = jun,
  journal = {Revista de Estudos Sociais},
  volume = {18},
  number = {36},
  pages = {172},
  issn = {2358-7024, 1519-504X},
  doi = {10.19093/res.v18i36.3309},
  url = {http://periodicoscientificos.ufmt.br/ojs/index.php/res/article/view/3309},
  urldate = {2025-08-12},
  abstract = {Criado com a finalidade de dirimir as desigualdades regionais entre as regi{\~o}es do pa{\'i}s, o Fundo Constitucional do Centro-Oeste (FCO) libera recursos atrav{\'e}s de projetos de investimento aos setores produtivos para gera{\c c}{\~a}o de empregos, renda, arrecada{\c c}{\~a}o tribut{\'a}ria e aumento no faturamento das empresas, garantindo recursos para {\`a}s pol{\'i}ticas regionais de desenvolvimento. A pesquisa justifica-se na necessidade de evidencia{\c c}{\~a}o de resultados, import{\^a}ncia das pol{\'i}ticas regionais de desenvolvimento e de integra{\c c}{\~a}o nacional. Assim, o objetivo geral do presente estudo {\'e} analisar a rela{\c c}{\~a}o entre a aplica{\c c}{\~a}o dos recursos do FCO e a gera{\c c}{\~a}o de empregos. Para responder esse questionamento, foram coletados dados em forma de painel antes e depois da reda{\c c}{\~a}o da Constitui{\c c}{\~a}o Federal (1988) que garante o repasse do fundo para os munic{\'i}pios da regi{\~a}o do centro-oeste. Por fim, Levantaram-se duas hip{\'o}teses: H0: a libera{\c c}{\~a}o de recursos do fundo n{\~a}o influencia o n{\'u}mero de empregos gerados e H1: caso contr{\'a}rio. Como resultados temos que o FCO no com{\'e}rcio gerou uma m{\'e}dia de 5.493 empregos, para a ind{\'u}stria 1.331 e para o setor de servi{\c c}os 3.559 vagas, correspondendo a 28\% das vagas geradas no per{\'i}odo, bem como o resultado de regress{\~a}o equivale a 65\% das vagas estimadas pelo programa na libera{\c c}{\~a}o dos investimentos.},
  langid = {portuguese}
}

@article{DeIMPACTOSDOSINCENTIVOS2019,
  title = {{IMPACTOS DOS INCENTIVOS FISCAIS NA INOVA{\c C}{\~A}O DE GRANDES EMPRESAS: UMA AVALIA{\c C}{\~A}O DAS EMPRESAS DA PESQUISA DA SONDAGEM DE INOVA{\c C}{\~A}O DA ABDI}},
  author = {{de}, Mar{\c c}o},
  year = {2019},
  abstract = {Tax incentives are the oldest instrument, and widely used by several countries, to expand innovative efforts either quantitatively or qualitatively. In Brazil, tax incentives have been granted since the beginning of the 1990s, but have reached only a few expressive number of companies. Given this scenario, this paper performs an analysis, based on a match of data from the Pesquisa Sondagem de Inova{\c c}{\~a}o from ABDI and from the Ministry of Communications, Science, Technology and Innovation on the granting of fiscal incentives Brazil. This analysis aims to captur the differences in the technological performance of companies that received such incentives and of companies that did not receive. The econometric analyzes carried out indicates that the impacts of fiscal incentives on the type of innovation performance varies according to sectors' technological intensity.},
  langid = {portuguese},
  keywords = {/unread,No DOI found}
}

