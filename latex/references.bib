  year = {2018a},
  month = dec,
  journal = {Nova Economia},
  volume = {28},
  number = {3},
  pages = {965--1000},
  issn = {1980-5381, 0103-6351},
  doi = {10.1590/0103-6351/3397},
  urldate = {2025-08-12},
  abstract = {Resumo O estudo avalia o Fundo Constitucional de Financiamento do Centro-Oeste (FCO) no Estado de Goi{\'a}s entre os anos de 2004 e 2011 por meio dos microdados da Rela{\c c}{\~a}o Anual de Informa{\c c}{\~o}es Sociais (Rais), e dos empr{\'e}stimos do Programa Empresarial do FCO. Os impactos dos financiamentos no crescimento do emprego e sal{\'a}rios das empresas instaladas no Estado foram estatisticamente significantes e positivos. Os m{\'e}todos utilizados foram o propensity score matching (PSM) e o propensity score generalizado (PSG), que trata a vari{\'a}vel tratamento como cont{\'i}nua, portanto, verifica os efeitos heterog{\^e}neos ao inv{\'e}s do impacto m{\'e}dio. Ademais, o efeito dose indica que o valor do empr{\'e}stimo influencia na quantidade de empregos gerados, assim como na varia{\c c}{\~a}o dos sal{\'a}rios. As evid{\^e}ncias apresentadas sugerem novos padr{\~o}es de heterogeneidade no efeito do programa e complementam os resultados previamente encontrados na literatura.},
  url = {https://doi.org/10.1590/0103-6351/3397}
}

