@article{Ferreira2024,
  title = {{A PNDR e o Desenvolvimento Econ{\^o}mico do Nordeste: Uma An{\'a}lise do FDNE e dos Incentivos Fiscais da SUDENE}},
  shorttitle = {{A PNDR e o Desenvolvimento Econ{\^o}mico do Nordeste}},
  author = {Ferreira, Wendel and Irffi, Guilherme and Carneiro, Diego},
  year = {2024},
  publisher = {Unpublished},
  doi = {10.13140/RG.2.2.29760.85766},
  url = {https://rgdoi.net/10.13140/RG.2.2.29760.85766},
  urldate = {2025-08-12},
  abstract = {This study evaluated the relationship between two instruments of the National Policy for Regional Development (PNDR) --- tax incentives and the FDNE --- and the economic development of municipalities in the SUDENE area of operation. To achieve this, the Municipal Development Indicator (IDM) was developed, composed of three components: education, health, and income. The analysis was divided into two stages: first, an exploratory spatial analysis identified patterns in the distribution of the IDM and the requests for incentives and FDNE. Subsequently, the Spatial Autoregressive Combined (SAC) econometric model was used to assess the impact of these instruments on municipal development. The results indicated a concentration of economic development in coastal capitals, with focal points in the interior of Cear{\'a}, northern Minas Gerais, and Esp{\'i}rito Santo. Only tax incentives had a significant impact on the IDM, primarily due to the reduction in infant mortality and an increase in GDP per capita. The FDNE showed a positive relationship only with the income sub-index. Spatial spillovers were observed for tax incentives, benefiting neighboring municipalities. This study contributes to the enhancement of PNDR policies by suggesting adjustments to maximize the use of public resources and promoting a new perspective on spatial dependence in regional development, particularly in northeastern Brazil.},
  langid = {portuguese}
}

