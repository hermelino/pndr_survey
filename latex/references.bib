@article{BastosBalancaComercialUma2017,
  title = {{A balan{\c c}a comercial {\'e} uma restri{\c c}{\~a}o ao crescimento econ{\^o}mico dos estados brasileiros? Uma an{\'a}lise para o per{\'i}odo de 1991 a 2009}},
