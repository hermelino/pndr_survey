@misc{ChenEfficientSequentialEstimation2025,
  title = {Efficient and {{Sequential Estimation}} of {{High-order Spatial Dynamic Panels}} with {{Time-varying Dominant Units}}},
  author = {Chen, Yahui and Han, Xiaoyi and Fei, Jin and Zhang, Jiajun},
  year = {2025},
  publisher = {SSRN},
  doi = {10.2139/ssrn.5167495},
  url = {https://www.ssrn.com/abstract=5167495},
  urldate = {2025-08-12},
  abstract = {In spatial and network panel data, dominant units can significantly influence others, invalidating standard estimation and inference methods. We study a highorder spatial dynamic panel data (SDPD) model with time-varying dominant units, where dominant units cause unbounded column sums in spatial weights matrices. We develop central limit theorems (CLTs) for linear-quadratic forms with heteroskedastic disturbances, characterizing how dominant units affect convergence rates. Our CLTs provide a unified framework that covers dominant units in different settings and only require the existence of fourth moments of disturbances. We further propose two moment-based estimators: the generalized method of moments estimator (GMME) and the root estimator (RTE). The RTE has a closed-form solution that does not involve any optimization algorithm and can achieve the same asymptotic efficiency as the best GMME. We establish the consistency and asymptotic normality of these estimators and show different convergence rates due to the influence of dominant units. We also extend the estimation methods to the case where spatial weights matrices are endogenous. Monte Carlo simulations demonstrate that our proposed estimators have satisfactory finite sample performance. An empirical application to the peer effects of financial decisions among Chinese listed firms, where dominant units exist, illustrates the merits of our proposed models and estimation methods.},
  archiveprefix = {SSRN},
  langid = {english},
  keywords = {/unread}
}

@article{CinganoMakingSubsidiesWork2025,
  title = {Making {{Subsidies Work}}: {{Rules}} versus {{Discretion}}},
  shorttitle = {Making {{Subsidies Work}}},
  author = {Cingano, Federico and Palomba, Filippo and Pinotti, Paolo and Rettore, Enrico},
  year = {2025},
  journal = {Econometrica},
  volume = {93},
  number = {3},
  pages = {747--778},
  issn = {0012-9682},
  doi = {10.3982/ECTA21319},
  url = {https://www.econometricsociety.org/doi/10.3982/ECTA21319},
  urldate = {2025-08-12},
  abstract = {We estimate the employment effects of a large program of public investment subsidies to private firms that ranked applicants on a score reflecting both objective rules and local politicians' discretion. Leveraging the rationing of funds as an ideal Regression Discontinuity Design, we characterize the heterogeneity of treatment effects and cost-per-new-job across inframarginal firms and estimate the cost-effectiveness of subsidies under factual and counterfactual allocations. Firms ranking high on objective rules and firms preferred by local politicians generated larger employment growth on average, but the latter did so at a higher cost per job. We estimate that relying only on objective criteria would reduce the cost per job by 11\%, while relying only on political discretion would increase such cost by 42\%.},
  copyright = {https://creativecommons.org/licenses/by/4.0/},
  langid = {english},
  keywords = {/unread}
}

